# Venice AI (required - get at https://venice.ai)
VENICE_API_KEY=your-venice-api-key-here

# Database mode: 'json' for local dev (flat-file in /data/), 'prisma' for production (PostgreSQL)
DATABASE=prisma

# Database (set automatically by Akash SDL - shown for local dev)
DATABASE_URL=postgresql://web3agent:changeme-secure-password-2024@localhost:5432/web3agent
DIRECT_URL=postgresql://web3agent:changeme-secure-password-2024@localhost:5432/web3agent

# Web3 RPC URLs (optional - defaults provided)
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# App Config
NEXTAUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Privy (required - get at https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here

# Treasury Wallet (for prefunding new users with USDC)
TREASURY_PRIVATE_KEY=your-treasury-wallet-private-key-here
TREASURY_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
